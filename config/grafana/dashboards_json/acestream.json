{
  "title": "Acestream Monitor",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Executions (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "increase(acestream_run_total[24h])", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Playlist Changes (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "increase(acestream_updates_with_changes[24h])", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "purple" }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Errors (24h)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "increase(acestream_update_errors[24h])", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Last Run",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "time() - acestream_last_run_timestamp", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 900 },
              { "color": "red", "value": 1800 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Activity Timeline",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "increase(acestream_run_total[5m])",
          "legendFormat": "Executions",
          "refId": "A"
        },
        {
          "expr": "increase(acestream_updates_with_changes[5m])",
          "legendFormat": "Changes",
          "refId": "B"
        },
        {
          "expr": "increase(acestream_update_errors[5m])",
          "legendFormat": "Errors",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "barAlignment": 0,
            "lineWidth": 0
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Executions" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Changes" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Errors" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      }
    }
  ]
}
