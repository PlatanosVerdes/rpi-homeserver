{
  "title": "Deploy Monitor",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Executions (24h)",
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 0 },
      "targets": [
        { "expr": "increase(deploy_run_total[24h])", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Deployments with Changes (24h)",
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 0 },
      "targets": [
        { "expr": "increase(deploy_with_changes_total[24h])", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Errors (24h)",
      "gridPos": { "h": 4, "w": 5, "x": 10, "y": 0 },
      "targets": [
        { "expr": "increase(deploy_errors_total[24h])", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Last Run",
      "gridPos": { "h": 4, "w": 4, "x": 15, "y": 0 },
      "targets": [
        { "expr": "time() - deploy_last_run_timestamp", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1800 },
              { "color": "red", "value": 3600 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Last Status",
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 0 },
      "targets": [
        { "expr": "deploy_last_status", "refId": "A", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "No changes", "color": "blue" } } },
            { "type": "value", "options": { "1": { "text": "Deployed", "color": "green" } } },
            { "type": "value", "options": { "2": { "text": "Error", "color": "red" } } }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Activity Timeline",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "increase(deploy_run_total[15m])",
          "legendFormat": "Executions",
          "refId": "A"
        },
        {
          "expr": "increase(deploy_with_changes_total[15m])",
          "legendFormat": "Deployed",
          "refId": "B"
        },
        {
          "expr": "increase(deploy_errors_total[15m])",
          "legendFormat": "Errors",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "barAlignment": 0,
            "lineWidth": 0
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Executions" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Deployed" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Errors" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          }
        ]
      }
    }
  ]
}
