{
  "title": "Live TV",
  "schemaVersion": 38,
  "graphTooltip": 1,
  "refresh": "2m",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "tags": ["livetv", "acestream"],
  "links": [],
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "health_filter",
        "label": "Show",
        "type": "custom",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [
          { "selected": true,  "text": "All",       "value": "acestream_channel_health" },
          { "selected": false, "text": "OK only",   "value": "acestream_channel_health == 1" },
          { "selected": false, "text": "Down only", "value": "acestream_channel_health == 0" }
        ],
        "current": { "selected": true, "text": "All", "value": "acestream_channel_health" },
        "query": "All : acestream_channel_health, OK only : acestream_channel_health == 1, Down only : acestream_channel_health == 0"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Channels OK",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "count(acestream_channel_health == 1)", "instant": true, "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value", "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Channels Down",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{ "expr": "count(acestream_channel_health == 0) or vector(0)", "instant": true, "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value", "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Channels",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{ "expr": "acestream_unique_channels", "instant": true, "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": 0 }] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value", "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Last Check",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{ "expr": "time() - acestream_last_run_timestamp", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "s", "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0 },
              { "color": "orange", "value": 600 },
              { "color": "red",    "value": 1800 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value", "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Channel Health",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 4 },
      "targets": [{ "expr": "$health_filter", "legendFormat": "{{name}}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepBefore",
            "lineWidth": 2,
            "fillOpacity": 5,
            "showPoints": "always",
            "pointSize": 5,
            "spanNulls": false
          },
          "decimals": 0,
          "min": 0,
          "max": 1,
          "mappings": [
            { "type": "value", "options": {
                "0": { "text": "Down", "index": 0 },
                "1": { "text": "OK",   "index": 1 }
            }}
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }] }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    }
  ]
}
