# Image versions — single source of truth (like requirements.txt).
#
# Bump a version here, commit, and the auto-deploy applies it.
# Loaded via COMPOSE_ENV_FILES=versions.env,.env (set by deploy/rebuild scripts).
# To run compose manually: export COMPOSE_ENV_FILES=versions.env,.env
#
# These are versions/digests, NOT secrets, so this file IS committed to git.

# --- core ---
CADDY_VERSION=2.10.2
HOMEPAGE_VERSION=v1.10.1
SPEEDTEST_TRACKER_VERSION=v1.13.10-ls138
PIHOLE_VERSION=2026.02.0

