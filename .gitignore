# Environment variables (CRITICAL - contains passwords and API keys)
.env

# Configuration directories (contains sensitive data)
config/

# EXCEPT: Public/safe configuration files (no credentials)
!config/homer/
!config/homer/config.yml
!config/prometheus/
!config/prometheus/prometheus.yml

# Configuration templates/examples (for documentation)
config-examples/

# Data directories (your actual files and media)
/mnt/data/

# Docker volumes and runtime data
*.log
*.pid
*.sock

# Temporary files
*.tmp
*.swp
*~
.DS_Store

# Backup files
*.backup
*.bak
*.old

# IDE and editor files
.vscode/
.idea/
*.sublime-*
.cursor/

# OS files
Thumbs.db
.Trash-*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/

# Node
node_modules/
npm-debug.log
yarn-error.log

# Secrets and keys (extra safety)
*.key
*.pem
*.crt
secrets/
credentials/