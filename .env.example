# Active profiles — controls which services start
# Profiles: essential, moni, acestream, media, bot, all
# all     → everything
# Use comma-separated values to combine profiles
COMPOSE_PROFILES=all

# Timezone
TZ=Europe/Madrid

# Static IP for Raspberry Pi (configure in your router's DHCP settings)
# Recommended: Reserve this IP in router for RPi's MAC address
# This IP will be used for Pi-hole DNS and as gateway for TV
STATIC_IP=192.168.1.xxx
TAILSCALE_IP=100.xxx.xx.xx

# User permissions (run: id -u and id -g to get your values)
PUID=1000
PGID=1000

# Base data path (path where you'll mount your external disk or RAID)
DATA_ROOT=/mnt/data
DATA_DB_ROOT=/mnt/data/db
CONFIG_ROOT=./config # Static config
APP_CONFIG_PATH=./appdata # Data app

# QBittorrent WebUI Port
QBIT_WEBUI_PORT=8080

# Telegram Bot Tokens
BOT_POL_ACADEMY_OFFERS_TOKEN="your_telegram_bot_token_here"

# Plex Claim Token
# Get your token at: https://www.plex.tv/claim/
# The token expires in 4 minutes, so copy it just before running docker compose up
PLEX_CLAIM="claim-your_plex_claim_token"

# Tailscale Auth Key
# Generate your key at: https://login.tailscale.com/admin/settings/keys
# Use a reusable and ephemeral "Auth key" if you prefer
TAILSCALE_AUTHKEY="tskey-auth-your_tailscale_auth_key"

# Pi-hole Web Password
# Password to access Pi-hole admin interface
PIHOLE_PASSWORD="your_secure_password"

# API Keys for *arr apps (get from Settings -> General -> Security -> API Key)
# You need to start the services first, then add these keys
PLEX_API_TOKEN=api_key #https://www.plexopedia.com/plex-media-server/general/plex-token/
OVERSEERR_API_KEY=api_key
PROWLARR_API_KEY=api_key
RADARR_API_KEY=api_key
SONARR_API_KEY=api_key
QBIT_PASSWORD="your_qbittorrent_password"
SPEEDTEST_KEY=base64:api_key #echo "base64:$(openssl rand -base64 32)"
SPEEDTEST_API_KEY=api_key
JELLYFIN_API_KEY=api_key

## NordVPN (optional, used by some containers for VPN routing)
NORDVPN_USER=your_nordvpn_service_user
NORDVPN_PASS=your_nordvpn_service_pass

# Cloudflare API Token (DNS challenge for Let's Encrypt certificates)
# Create at: Cloudflare Dashboard -> My Profile -> API Tokens -> Edit zone DNS template
# Scope: Zone -> DNS -> Edit, limited to your domain only
CF_API_TOKEN=your_cloudflare_api_token

# Email for Let's Encrypt certificate notifications (used by Caddy)
CADDY_EMAIL=your@email.com

# Google Calendar Bridge (cal-bridge)
# OAuth2 credentials from Google Cloud Console (https://console.cloud.google.com)
# Create an OAuth2 "Web application" credential, add https://cal.platanosverdes.com/callback as redirect URI
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Random secret used by the ESP32 to authenticate requests (generate with: openssl rand -hex 16)
CAL_API_KEY=your_random_secret
# Public base URL for OAuth2 redirect (default used if not set: https://cal.platanosverdes.com)
# CAL_BASE_URL=https://cal.platanosverdes.com
# Microsoft / Outlook (optional — only needed if you want to add an Outlook/M365 account)
# Register an app at https://portal.azure.com → App registrations
# Add redirect URI: https://cal.platanosverdes.com/callback/microsoft
# Grant delegated permission: Microsoft Graph → Calendars.Read
# MS_CLIENT_ID=your_azure_app_client_id
# MS_CLIENT_SECRET=your_azure_app_client_secret