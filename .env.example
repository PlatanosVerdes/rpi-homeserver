# Timezone
TZ=Europe/Madrid

# Network Configuration
HOSTNAME=banana
DOMAIN=banana.lan

# User permissions (run: id -u and id -g to get your values)
PUID=1000
PGID=1000

# Base data path (path where you'll mount your external disk or RAID)
DATA_PATH=/mnt/data

# Plex Claim Token
# Get your token at: https://www.plex.tv/claim/
# The token expires in 4 minutes, so copy it just before running docker compose up
PLEX_CLAIM=

# Tailscale Auth Key
# Generate your key at: https://login.tailscale.com/admin/settings/keys
# Use a reusable and ephemeral "Auth key" if you prefer
TAILSCALE_AUTHKEY=

# Pi-hole Web Password
# Password to access Pi-hole admin interface
PIHOLE_PASSWORD=your_secure_password

# Grafana Credentials
# Access Grafana web interface
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_secure_password

# Pi-hole Exporter (for monitoring)
PIHOLE_HOSTNAME=127.0.0.1
PIHOLE_PORT=80

# API Keys for *arr apps (get from Settings -> General -> Security -> API Key)
# You need to start the services first, then add these keys
RADARR_API_KEY=your_radarr_api_key_here
SONARR_API_KEY=your_sonarr_api_key_here
PROWLARR_API_KEY=your_prowlarr_api_key_here
